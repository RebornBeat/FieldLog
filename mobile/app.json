{
  "expo": {
    "name": "MetaStrata",
    "slug": "metastrata",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "metastrata",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0B0E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ungatedminds.metastrata",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "MetaStrata uses the camera to scan QR codes for device-to-device file transfer.",
        "NSPhotoLibraryUsageDescription": "MetaStrata can read files from your photo library.",
        "LSSupportsOpeningDocumentsInPlace": true,
        "UIFileSharingEnabled": true,
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "MetaStrata Archive",
            "CFBundleTypeRole": "Editor",
            "LSItemContentTypes": ["com.ungatedminds.stratum"],
            "LSHandlerRank": "Owner"
          },
          {
            "CFBundleTypeName": "MetaStrata Collection",
            "CFBundleTypeRole": "Editor",
            "LSItemContentTypes": ["com.ungatedminds.strata"],
            "LSHandlerRank": "Owner"
          }
        ],
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.ungatedminds.stratum",
            "UTTypeDescription": "MetaStrata Archive",
            "UTTypeConformsTo": ["public.zip-archive"],
            "UTTypeTagSpecification": { "public.filename-extension": ["stratum"] }
          },
          {
            "UTTypeIdentifier": "com.ungatedminds.strata",
            "UTTypeDescription": "MetaStrata Collection",
            "UTTypeConformsTo": ["public.zip-archive"],
            "UTTypeTagSpecification": { "public.filename-extension": ["strata"] }
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0B0E"
      },
      "package": "com.ungatedminds.metastrata",
      "versionCode": 1,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            { "scheme": "content", "mimeType": "application/octet-stream" },
            { "scheme": "file",    "mimeType": "application/octet-stream" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [{ "scheme": "metastrata" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      ["expo-camera",         { "cameraPermission": "Allow MetaStrata to access your camera to scan QR codes." }],
      ["expo-document-picker",{ "iCloudContainerEnvironment": "Production" }],
      "expo-file-system",
      "@react-native-async-storage/async-storage"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
